page {
  min-height: 100vh;
  color: #ffffff;
  background: #07142f;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx 72rpx;
  background:
    linear-gradient(90deg, rgba(255,255,255,0.035) 0 2rpx, transparent 2rpx 42rpx),
    linear-gradient(0deg, rgba(255,255,255,0.035) 0 2rpx, transparent 2rpx 42rpx),
    radial-gradient(circle at 20% 0%, rgba(8,217,214,.18), transparent 32%),
    radial-gradient(circle at 84% 12%, rgba(246,196,83,.16), transparent 30%),
    linear-gradient(145deg, #07142f 0%, #0d244f 52%, #07142f 100%);
}

.glass-card,
.pixel-panel,
.pixel-card {
  position: relative;
  border: 2rpx solid rgba(8, 217, 214, 0.28);
  border-radius: 24rpx;
  background: rgba(8, 20, 47, 0.82);
  box-shadow: 8rpx 8rpx 0 rgba(0, 0, 0, 0.36), inset 0 0 0 2rpx rgba(255,255,255,0.08);
  overflow: hidden;
}

.glass-card::after,
.pixel-panel::after,
.pixel-card::after {
  content: '';
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 12rpx;
  height: 2rpx;
  background: rgba(255,255,255,0.18);
}

.primary-button,
.ghost-button,
.pill-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-weight: 950;
  letter-spacing: 1rpx;
}

.primary-button {
  border: 2rpx solid rgba(255,255,255,.55);
  color: #07142f;
  font-size: 30rpx;
  background: linear-gradient(135deg, #08d9d6, #f6c453);
  box-shadow: 8rpx 8rpx 0 rgba(0,0,0,.42), inset -6rpx -6rpx 0 rgba(0,0,0,.12);
}

.primary-button:active,
.ghost-button:active,
.pill-button:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 rgba(0,0,0,.42);
}

.ghost-button {
  border: 2rpx solid rgba(246, 196, 83, 0.62);
  color: #f6c453;
  font-size: 28rpx;
  background: rgba(7, 20, 47, 0.72);
  box-shadow: 8rpx 8rpx 0 rgba(0,0,0,.30);
}

.tiny-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border: 3rpx solid rgba(255,255,255,.78);
  border-radius: 8rpx;
  color: #071A0F;
  background: #FFD84D;
  font-size: 22rpx;
  font-weight: 950;
}

.eyebrow {
  color: #08d9d6;
  font-size: 22rpx;
  font-weight: 950;
  letter-spacing: 4rpx;
}

.title {
  color: #ffffff;
  font-weight: 950;
  text-shadow: 4rpx 4rpx 0 rgba(0,0,0,.42);
}
