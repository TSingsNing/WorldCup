page {
  min-height: 100vh;
  color: #ffffff;
  background: #0B2B18;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx 72rpx;
  background:
    linear-gradient(90deg, rgba(255,255,255,0.035) 0 2rpx, transparent 2rpx 42rpx),
    linear-gradient(0deg, rgba(255,255,255,0.035) 0 2rpx, transparent 2rpx 42rpx),
    repeating-linear-gradient(90deg, #0B2B18 0 72rpx, #123D22 72rpx 144rpx);
}

.glass-card,
.pixel-panel,
.pixel-card {
  position: relative;
  border: 4rpx solid rgba(124, 255, 107, 0.72);
  border-radius: 14rpx;
  background: rgba(5, 25, 14, 0.88);
  box-shadow: 8rpx 8rpx 0 rgba(0, 0, 0, 0.36), inset 0 0 0 2rpx rgba(255,255,255,0.08);
  overflow: hidden;
}

.glass-card::after,
.pixel-panel::after,
.pixel-card::after {
  content: '';
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 12rpx;
  height: 2rpx;
  background: rgba(255,255,255,0.18);
}

.primary-button,
.ghost-button,
.pill-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 10rpx;
  font-weight: 950;
  letter-spacing: 1rpx;
}

.primary-button {
  border: 4rpx solid #E7FFD8;
  color: #071A0F;
  font-size: 30rpx;
  background: #7CFF6B;
  box-shadow: 8rpx 8rpx 0 rgba(0,0,0,.42), inset -6rpx -6rpx 0 rgba(0,0,0,.12);
}

.primary-button:active,
.ghost-button:active,
.pill-button:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 rgba(0,0,0,.42);
}

.ghost-button {
  border: 4rpx solid rgba(255, 216, 77, 0.78);
  color: #FFD84D;
  font-size: 28rpx;
  background: rgba(11, 43, 24, 0.76);
  box-shadow: 8rpx 8rpx 0 rgba(0,0,0,.30);
}

.tiny-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border: 3rpx solid rgba(255,255,255,.78);
  border-radius: 8rpx;
  color: #071A0F;
  background: #FFD84D;
  font-size: 22rpx;
  font-weight: 950;
}

.eyebrow {
  color: #7CFF6B;
  font-size: 22rpx;
  font-weight: 950;
  letter-spacing: 4rpx;
}

.title {
  color: #ffffff;
  font-weight: 950;
  text-shadow: 4rpx 4rpx 0 rgba(0,0,0,.42);
}
