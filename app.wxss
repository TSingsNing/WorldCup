page {
  min-height: 100vh;
  color: #ffffff;
  background: #07142f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx 64rpx;
  background:
    radial-gradient(circle at 12% 8%, rgba(8, 217, 214, 0.34), transparent 27%),
    radial-gradient(circle at 90% 1%, rgba(255, 90, 120, 0.24), transparent 25%),
    radial-gradient(circle at 50% 100%, rgba(246, 196, 83, 0.18), transparent 30%),
    linear-gradient(180deg, #07142f 0%, #0b1f45 46%, #061124 100%);
}

.glass-card {
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.09);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.24);
  backdrop-filter: blur(18rpx);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 999rpx;
  color: #061124;
  font-size: 32rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #08d9d6 0%, #f6c453 56%, #ff5a78 100%);
  box-shadow: 0 18rpx 42rpx rgba(8, 217, 214, 0.28);
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 30rpx;
  background: rgba(255, 255, 255, 0.08);
}

.tiny-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #061124;
  background: #f6c453;
  font-size: 22rpx;
  font-weight: 900;
}
