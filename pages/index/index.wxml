<view class="container home-page pixel-home" bindtouchstart="onPageTouch">
  <view class="top-actions">
    <view class="pill-button" bindtap="toggleMusic">{{musicOn ? 'BGM 开' : '开 BGM'}}</view>
    <view class="pill-button outline" bindtap="goLeaderboard">好友榜</view>
  </view>

  <view class="hero pixel-hero">
    <view class="hero-copy">
      <view class="eyebrow">WORLD CUP TYPE INDICATOR</view>
      <view class="title">WCTI世界杯人格测试</view>
      <view class="subtitle">测球格，开球。终场发证。</view>
    </view>
    <view class="hero-pitch" aria-hidden="true">
      <view class="stand-row"><text></text><text></text><text></text><text></text></view>
      <view class="pixel-cup"><view class="cup-head"></view><view class="cup-body"></view><view class="cup-base"></view></view>
      <view class="pixel-ball"></view>
    </view>
  </view>

  <view class="match-kit">
    <view class="kit-card"><view class="kit-icon">90'</view><view class="kit-text">开球</view></view>
    <view class="kit-card hot"><view class="kit-icon">TOP</view><view class="kit-text">冲榜</view></view>
    <view class="kit-card"><view class="kit-icon">CUP</view><view class="kit-text">发证</view></view>
  </view>

  <view class="section-title">选择难度</view>
  <view class="difficulty-list">
    <view class="difficulty-card glass-card" wx:for="{{difficulties}}" wx:key="key" bindtap="startQuiz" data-key="{{item.key}}">
      <view class="difficulty-top">
        <view class="difficulty-main">
          <view class="difficulty-name">{{item.name}}</view>
          <view class="difficulty-vibe">{{item.vibe}}</view>
        </view>
        <view class="question-count">{{item.count}} 题</view>
      </view>
      <view class="difficulty-bottom">
        <view class="badge">{{item.badge}}</view>
        <view class="arrow">开球 →</view>
      </view>
    </view>
  </view>
</view>
