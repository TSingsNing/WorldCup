.home-page { overflow: hidden; padding-top: 32rpx; }
.top-actions { display: flex; gap: 16rpx; margin-bottom: 26rpx; }
.pill-button { flex: 1; min-height: 72rpx; border: 4rpx solid #E7FFD8; color: #071A0F; background: #7CFF6B; font-size: 23rpx; box-shadow: 6rpx 6rpx 0 rgba(0,0,0,.38); }
.pill-button.outline { color: #FFD84D; background: rgba(11,43,24,.86); border-color: #FFD84D; }
.pixel-hero { padding: 24rpx 26rpx; }
.title { margin-top: 12rpx; font-size: 56rpx; line-height: 1.06; }
.subtitle { margin-top: 16rpx; color: rgba(255,255,255,.82); font-size: 27rpx; line-height: 1.45; }
.section-title { margin: 34rpx 0 18rpx; font-size: 32rpx; font-weight: 950; color: #FFD84D; text-shadow: 4rpx 4rpx 0 rgba(0,0,0,.38); }
.difficulty-list { display: flex; flex-direction: column; gap: 18rpx; }
.difficulty-card { padding: 24rpx 26rpx; }
.difficulty-card:active { transform: translate(4rpx, 4rpx); }
.difficulty-top, .difficulty-bottom { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.difficulty-main { min-width: 0; flex: 1; }
.difficulty-name { font-size: 32rpx; font-weight: 950; color: #ffffff; }
.difficulty-vibe { margin-top: 6rpx; color: rgba(255,255,255,.68); font-size: 22rpx; line-height: 1.35; }
.question-count { padding: 7rpx 12rpx; border: 3rpx solid #0B2B18; border-radius: 6rpx; color: #071A0F; background: #FFD84D; font-size: 21rpx; font-weight: 950; white-space: nowrap; }
.difficulty-bottom { margin-top: 18rpx; }
.badge { color: #7CFF6B; font-size: 23rpx; font-weight: 950; }
.arrow { color: #FFD84D; font-size: 25rpx; font-weight: 950; }
