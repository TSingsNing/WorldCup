.prophet-home { padding-bottom: 48rpx; }
.top-actions { display: flex; justify-content: flex-end; gap: 16rpx; margin-bottom: 24rpx; }
.hero-card { position: relative; overflow: hidden; padding: 40rpx 32rpx; border-color: rgba(8, 217, 214, 0.35); }
.hero-card::after { content: ''; position: absolute; right: -80rpx; top: -80rpx; width: 260rpx; height: 260rpx; border-radius: 50%; background: radial-gradient(circle, rgba(8,217,214,.32), rgba(8,217,214,0)); }
.eyebrow { color: #08d9d6; font-size: 22rpx; letter-spacing: 4rpx; font-weight: 700; }
.title { margin-top: 12rpx; color: #fff; font-size: 58rpx; line-height: 1.05; font-weight: 900; }
.subtitle { margin-top: 16rpx; color: rgba(255,255,255,.78); font-size: 26rpx; line-height: 1.6; }
.hero-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx; margin-top: 30rpx; }
.stat-box { padding: 18rpx 10rpx; border-radius: 18rpx; background: rgba(255,255,255,.08); text-align: center; color: rgba(255,255,255,.7); font-size: 22rpx; }
.stat-num { display: block; color: #f6c453; font-size: 34rpx; font-weight: 900; margin-bottom: 4rpx; }
.hero-actions { display: grid; grid-template-columns: 1.3fr 1fr; gap: 18rpx; margin-top: 30rpx; }
.persona-strip { margin-top: 22rpx; display: flex; justify-content: space-between; align-items: center; }
.compact { margin: 0 0 8rpx; font-size: 24rpx; }
.persona-name { color: #f6c453; font-size: 38rpx; font-weight: 900; }
.persona-slogan, .room-copy { color: rgba(255,255,255,.72); font-size: 24rpx; line-height: 1.55; }
.mini-cup { width: 104rpx; height: 104rpx; border: 4rpx solid #f6c453; color: #f6c453; display: flex; align-items: center; justify-content: center; font-weight: 900; border-radius: 28rpx; box-shadow: 0 0 20rpx rgba(246,196,83,.22); }
.feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; margin-top: 22rpx; }
.feature-card { padding: 22rpx; border-radius: 22rpx; background: linear-gradient(145deg, rgba(255,255,255,.1), rgba(255,255,255,.04)); border: 1rpx solid rgba(255,255,255,.12); }
.feature-value { display: inline-block; padding: 6rpx 12rpx; border-radius: 999rpx; color: #07142f; background: #08d9d6; font-size: 20rpx; font-weight: 800; }
.feature-title { margin-top: 16rpx; color: #fff; font-size: 30rpx; font-weight: 800; }
.feature-desc { margin-top: 8rpx; color: rgba(255,255,255,.66); font-size: 22rpx; line-height: 1.45; }
.section-head { display: flex; justify-content: space-between; align-items: center; margin-top: 32rpx; }
.section-more { color: #08d9d6; font-size: 24rpx; }
.match-list { display: flex; flex-direction: column; gap: 16rpx; }
.match-card { padding: 24rpx; }
.match-top { display: flex; justify-content: space-between; color: rgba(255,255,255,.66); font-size: 22rpx; }
.hot { color: #ff6b6b; font-weight: 800; }
.teams { display: grid; grid-template-columns: 1fr 70rpx 1fr; align-items: center; gap: 10rpx; margin-top: 16rpx; color: #fff; font-size: 30rpx; font-weight: 900; }
.teams text:last-child { text-align: right; }
.vs { color: #f6c453; text-align: center !important; font-size: 24rpx; }
.match-meta { margin-top: 12rpx; color: rgba(255,255,255,.58); font-size: 22rpx; }
.room-card { margin-top: 24rpx; display: flex; gap: 20rpx; justify-content: space-between; align-items: center; }
.small-button { flex: 0 0 160rpx; min-height: 72rpx; line-height: 72rpx; border-radius: 18rpx; border: 0; color: #07142f; background: #f6c453; font-size: 24rpx; font-weight: 900; }
.recent-card { margin-top: 24rpx; padding: 24rpx; }
.recent-item { display: flex; justify-content: space-between; padding: 14rpx 0; border-top: 1rpx solid rgba(255,255,255,.08); color: rgba(255,255,255,.76); font-size: 24rpx; }
.notice-card { margin-top: 24rpx; padding: 22rpx; border-radius: 18rpx; background: rgba(255,107,107,.1); border: 1rpx solid rgba(255,107,107,.28); color: rgba(255,255,255,.75); font-size: 22rpx; line-height: 1.55; }
