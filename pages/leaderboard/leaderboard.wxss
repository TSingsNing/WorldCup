.eyebrow { color: #08d9d6; font-size: 22rpx; font-weight: 900; letter-spacing: 4rpx; }
.title { margin-top: 14rpx; font-size: 54rpx; font-weight: 950; }
.subtitle { margin-top: 18rpx; color: rgba(255,255,255,.72); font-size: 27rpx; line-height: 1.7; }
.board-list { margin-top: 34rpx; display: flex; flex-direction: column; gap: 18rpx; }
.rank-card { display: flex; align-items: center; gap: 20rpx; padding: 26rpx; }
.rank-card.mine { border-color: rgba(246,196,83,.7); background: rgba(246,196,83,.14); }
.rank-num { width: 74rpx; color: #f6c453; font-size: 30rpx; font-weight: 950; }
.rank-main { flex: 1; min-width: 0; }
.name-row { display: flex; align-items: center; gap: 12rpx; }
.name { font-size: 30rpx; font-weight: 900; }
.me-tag { padding: 4rpx 12rpx; border-radius: 999rpx; color: #061124; background: #08d9d6; font-size: 20rpx; font-weight: 900; }
.meta { margin-top: 8rpx; color: rgba(255,255,255,.66); font-size: 23rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.score { color: #08d9d6; font-size: 32rpx; font-weight: 950; }
.bottom { margin-top: 34rpx; }
