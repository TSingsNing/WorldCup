.leaderboard-page { padding-bottom: 48rpx; }
.hero { padding: 32rpx; }
.eyebrow { color: #08d9d6; font-size: 22rpx; letter-spacing: 4rpx; font-weight: 800; }
.page-title { margin-top: 10rpx; color: #fff; font-size: 52rpx; font-weight: 950; }
.page-subtitle { margin-top: 10rpx; color: rgba(255,255,255,.7); font-size: 24rpx; line-height: 1.55; }
.room-card, .rules-card { margin-top: 22rpx; }
.compact { margin: 0 0 12rpx; font-size: 28rpx; }
.room-line, .rule-line { color: rgba(255,255,255,.72); font-size: 24rpx; line-height: 1.55; margin-top: 8rpx; }
.room-options { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 20rpx; }
.room-chip { padding: 14rpx 18rpx; border-radius: 999rpx; background: rgba(255,255,255,.08); color: rgba(255,255,255,.72); font-size: 23rpx; border: 1rpx solid rgba(255,255,255,.12); }
.room-chip.active { color: #07142f; background: #f6c453; border-color: #f6c453; font-weight: 900; }
.leader-list { margin-top: 22rpx; display: flex; flex-direction: column; gap: 14rpx; }
.leader-item { display: grid; grid-template-columns: 70rpx 1fr 110rpx; align-items: center; gap: 16rpx; padding: 22rpx; border-radius: 22rpx; background: rgba(255,255,255,.08); border: 1rpx solid rgba(255,255,255,.12); }
.leader-item.mine { border-color: rgba(8,217,214,.6); background: rgba(8,217,214,.12); }
.rank { width: 58rpx; height: 58rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; color: #07142f; background: rgba(255,255,255,.7); font-size: 26rpx; font-weight: 950; }
.rank-1 { background: #f6c453; }
.rank-2 { background: #d7e2ff; }
.rank-3 { background: #ffb07c; }
.leader-name { color: #fff; font-size: 28rpx; font-weight: 900; }
.leader-meta { margin-top: 6rpx; color: rgba(255,255,255,.58); font-size: 21rpx; line-height: 1.35; }
.leader-score { text-align: right; }
.leader-score text:first-child { display: block; color: #f6c453; font-size: 32rpx; font-weight: 950; }
.leader-score text:last-child { display: block; color: rgba(255,255,255,.6); font-size: 21rpx; margin-top: 4rpx; }
.rules-card { padding: 24rpx; }
.bottom-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 22rpx; }
.notice-card { margin-top: 24rpx; padding: 22rpx; border-radius: 18rpx; background: rgba(255,107,107,.1); border: 1rpx solid rgba(255,107,107,.28); color: rgba(255,255,255,.72); font-size: 22rpx; line-height: 1.55; }
