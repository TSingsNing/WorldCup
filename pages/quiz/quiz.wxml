<view class="container predict-page">
  <view class="predict-top">
    <view>
      <view class="eyebrow">DAILY PROPHET</view>
      <view class="page-title">今日娱乐预测</view>
      <view class="page-subtitle">选择赛程，锁定你的站队理由。</view>
    </view>
    <view class="pill-button music" bindtap="toggleMusic">{{musicOn ? 'BGM 开' : '开 BGM'}}</view>
  </view>

  <scroll-view class="match-tabs" scroll-x="true" enable-flex="true">
    <view class="match-tab {{selectedMatchId === item.id ? 'active' : ''}}" wx:for="{{matches}}" wx:key="id" data-id="{{item.id}}" bindtap="selectMatch">
      <text>{{item.date}}</text>
      <text>{{item.tag}}</text>
    </view>
  </scroll-view>

  <view class="current-match glass-card">
    <view class="match-meta">{{current.stage}} · {{current.group}} · {{current.venue}}</view>
    <view class="teams"><text>{{current.home}}</text><text class="vs">VS</text><text>{{current.away}}</text></view>
    <view class="match-time">{{current.date}} {{current.time}} · 热度 {{current.heat}}</view>
    <view class="story">{{current.story}}</view>
  </view>

  <view class="ai-card pixel-panel">
    <view class="section-title compact">AI 赛前分析师</view>
    <view class="ai-line"><text>走势</text>{{current.ai.trend}}</view>
    <view class="ai-line"><text>看点</text>{{current.ai.key}}</view>
    <view class="ai-line"><text>比分</text>{{current.ai.score}}</view>
    <view class="ai-line"><text>爆冷</text>{{current.ai.upset}}</view>
    <view class="ai-notice">以上仅为娱乐分析，不构成任何投注、交易或收益建议。</view>
  </view>

  <view class="form-card glass-card">
    <view class="section-title compact">我的预测</view>

    <view class="field-title">赛果选择</view>
    <view class="option-grid four">
      <view class="option {{form.result === item ? 'selected' : ''}}" wx:for="{{resultOptions}}" wx:key="*this" data-value="{{item}}" bindtap="chooseResult">{{item}}</view>
    </view>

    <view class="field-title">比分剧本</view>
    <view class="option-grid three">
      <view class="option {{form.score === item ? 'selected' : ''}}" wx:for="{{scoreOptions}}" wx:key="*this" data-value="{{item}}" bindtap="chooseScore">{{item}}</view>
    </view>

    <view class="field-title">进球区间</view>
    <view class="option-grid three">
      <view class="option {{form.goals === item ? 'selected' : ''}}" wx:for="{{goalOptions}}" wx:key="*this" data-value="{{item}}" bindtap="chooseGoals">{{item}}</view>
    </view>

    <view class="field-title">首球时间</view>
    <view class="option-grid two">
      <view class="option {{form.firstGoal === item ? 'selected' : ''}}" wx:for="{{firstGoalOptions}}" wx:key="*this" data-value="{{item}}" bindtap="chooseFirstGoal">{{item}}</view>
    </view>

    <view class="field-title">冠军与金靴长期预测</view>
    <scroll-view class="chips" scroll-x="true" enable-flex="true">
      <view class="chip {{form.champion === item ? 'selected' : ''}}" wx:for="{{championTeams}}" wx:key="*this" data-value="{{item}}" bindtap="chooseChampion">{{item}}</view>
    </scroll-view>
    <scroll-view class="chips" scroll-x="true" enable-flex="true">
      <view class="chip boot {{form.goldenBoot === item ? 'selected' : ''}}" wx:for="{{goldenBootPlayers}}" wx:key="*this" data-value="{{item}}" bindtap="chooseGoldenBoot">{{item}}</view>
    </scroll-view>

    <view class="field-title">站队理由</view>
    <textarea class="reason-input" maxlength="80" value="{{form.reason}}" bindinput="onReasonInput" placeholder="写一句你的玄学或战术理由" />

    <button class="primary-button submit" bindtap="submitPrediction">保存娱乐预测</button>
  </view>

  <view class="saved-card pixel-card" wx:if="{{saved}}">
    <view class="section-title compact">保存成功</view>
    <view class="saved-main">+{{saved.points}} 热力积分</view>
    <view class="saved-line">{{saved.statusText}}</view>
    <view class="saved-actions">
      <button class="ghost-button" bindtap="goCard">生成身份卡</button>
      <button class="ghost-button" bindtap="goLeaderboard">看好友榜</button>
    </view>
  </view>

  <view class="notice-card">{{notice}}</view>
</view>
