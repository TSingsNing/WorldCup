<view class="container quiz-page pixel-field">
  <view class="scoreboard pixel-panel">
    <view class="score-main">
      <view class="eyebrow">{{quiz.name}}</view>
      <view class="title">第 {{currentIndex + 1}} / {{total}} 题</view>
      <view class="roast">{{broadcastTitle}} · {{broadcastLine}}</view>
    </view>
    <view class="score-box">
      <view class="score-num">{{score}}</view>
      <view class="score-label">进球</view>
      <view class="miss-label">失误 {{wrongCount}}</view>
    </view>
  </view>

  <view class="pixel-progress">
    <view class="progress-grass" style="width: {{progress}}%;"></view>
  </view>

  <view class="question-card pixel-card">
    <view class="field-lines">
      <view class="center-circle"></view>
    </view>
    <view class="question-text">{{currentQuestion.question}}</view>
    <view class="option-list">
      <view wx:for="{{currentQuestion.options}}" wx:key="*this" data-index="{{index}}" bindtap="chooseOption" class="option-card {{selectedIndex === index ? (isCorrect ? 'option-correct' : 'option-wrong') : ''}} {{showAnswer && index === currentQuestion.answer ? 'option-correct' : ''}}">
        <view class="option-letter">{{letters[index]}}</view>
        <view class="option-text">{{item}}</view>
      </view>
    </view>

    <view wx:if="{{showAnswer}}" class="feedback-card {{isCorrect ? 'success' : 'fail'}}">
      <view class="feedback-title">{{isCorrect ? '命中！' : '答案解析'}}</view>
      <view class="feedback-desc">{{isCorrect ? broadcastLine : currentQuestion.explanation}}</view>
      <view wx:if="{{!isCorrect}}" class="feedback-action">
        <view wx:if="{{!isLast}}" class="primary-button pixel-button compact-button" bindtap="nextQuestion">下一题</view>
        <view wx:if="{{isLast}}" class="primary-button pixel-button compact-button" bindtap="goCertificate">生成证书</view>
      </view>
    </view>
  </view>
</view>
