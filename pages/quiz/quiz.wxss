.quiz-page { height: 100vh; min-height: 100vh; box-sizing: border-box; overflow: hidden; padding: 20rpx 24rpx 22rpx; display: flex; flex-direction: column; }
.scoreboard { flex-shrink: 0; display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; padding: 22rpx 26rpx; }
.score-main { min-width: 0; flex: 1; }
.title { margin-top: 6rpx; font-size: 46rpx; line-height: 1.06; }
.roast { margin-top: 8rpx; color: rgba(255,255,255,.84); font-size: 28rpx; line-height: 1.24; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.score-box { flex-shrink: 0; min-width: 128rpx; padding: 14rpx 12rpx; border: 4rpx solid #FFD84D; border-radius: 10rpx; background: rgba(255,216,77,.12); text-align: center; }
.score-num { color: #FFD84D; font-size: 50rpx; font-weight: 950; line-height: 1; }
.score-label, .miss-label { margin-top: 5rpx; color: rgba(255,255,255,.78); font-size: 23rpx; font-weight: 900; }
.miss-label { color: #FFB7A5; }
.broadcast-strip { display: none; }
.pixel-progress { flex-shrink: 0; margin-top: 14rpx; height: 22rpx; border: 3rpx solid rgba(255,255,255,.72); border-radius: 8rpx; background: rgba(0,0,0,.30); overflow: hidden; box-shadow: 5rpx 5rpx 0 rgba(0,0,0,.32); }
.progress-grass { height: 100%; background: repeating-linear-gradient(90deg, #7CFF6B 0 24rpx, #FFD84D 24rpx 32rpx); transition: width .25s ease; }
.question-card { flex: 1; min-height: 0; margin-top: 14rpx; padding: 28rpx; display: flex; flex-direction: column; justify-content: flex-start; }
.field-lines { pointer-events: none; position: absolute; inset: 0; opacity: .13; border: 4rpx solid #ffffff; }
.field-lines::before { content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 4rpx; background: #ffffff; }
.center-circle { position: absolute; left: 50%; top: 50%; width: 146rpx; height: 146rpx; margin-left: -73rpx; margin-top: -73rpx; border: 4rpx solid #ffffff; border-radius: 50%; }
.question-text { position: relative; flex-shrink: 0; font-size: 40rpx; line-height: 1.26; font-weight: 950; }
.option-list { position: relative; flex-shrink: 0; margin-top: 28rpx; display: flex; flex-direction: column; gap: 18rpx; }
.option-card { display: flex; align-items: center; gap: 18rpx; min-height: 98rpx; padding: 14rpx 18rpx; border: 4rpx solid rgba(255,255,255,.24); border-radius: 10rpx; background: rgba(11,43,24,.90); box-shadow: 4rpx 4rpx 0 rgba(0,0,0,.28); }
.option-card:active { transform: translate(3rpx, 3rpx); box-shadow: 2rpx 2rpx 0 rgba(0,0,0,.30); }
.option-letter { display: flex; align-items: center; justify-content: center; width: 64rpx; height: 64rpx; border: 3rpx solid #071A0F; border-radius: 6rpx; color: #071A0F; background: #ffffff; font-size: 33rpx; font-weight: 950; }
.option-text { flex: 1; color: #ffffff; font-size: 35rpx; line-height: 1.20; font-weight: 900; }
.option-correct { border-color: #7CFF6B; background: rgba(37, 122, 52, .92); }
.option-wrong { border-color: #FF7A59; background: rgba(119, 36, 28, .92); }
.result-card { position: relative; flex-shrink: 0; margin-top: auto; min-height: 224rpx; padding: 22rpx; border: 4rpx solid #FFD84D; border-radius: 10rpx; background: rgba(0,0,0,.30); box-shadow: inset 0 0 0 2rpx rgba(255,255,255,.08); }
.result-card.idle { border-color: rgba(255,255,255,.35); background: rgba(5,25,14,.58); }
.result-card.success { border-color: #7CFF6B; }
.result-card.fail { border-color: #FF7A59; }
.result-head { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.result-tag { color: #FFD84D; font-size: 33rpx; font-weight: 950; }
.result-status { padding: 8rpx 13rpx; border-radius: 6rpx; color: #071A0F; background: #E7FFD8; font-size: 27rpx; font-weight: 950; white-space: nowrap; }
.answer-row { display: flex; gap: 12rpx; margin-top: 14rpx; }
.answer-pill { flex: 1; padding: 12rpx 12rpx; border: 3rpx solid rgba(255,255,255,.34); border-radius: 8rpx; color: #ffffff; font-size: 29rpx; font-weight: 950; text-align: center; }
.answer-pill.truth { border-color: #7CFF6B; color: #7CFF6B; }
.answer-pill.mine { border-color: #FFD84D; color: #FFD84D; }
.result-desc { margin-top: 14rpx; color: rgba(255,255,255,.90); font-size: 30rpx; line-height: 1.26; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.feedback-action { margin-top: 14rpx; }
.compact-button { min-height: 82rpx; font-size: 33rpx; box-shadow: 5rpx 5rpx 0 rgba(0,0,0,.38), inset -4rpx -4rpx 0 rgba(0,0,0,.12); }
