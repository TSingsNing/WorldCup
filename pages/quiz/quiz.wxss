.predict-page { padding-bottom: 48rpx; }
.predict-top { display: flex; justify-content: space-between; gap: 20rpx; align-items: center; margin-bottom: 22rpx; }
.eyebrow { color: #08d9d6; font-size: 22rpx; letter-spacing: 4rpx; font-weight: 800; }
.page-title { color: #fff; font-size: 50rpx; line-height: 1.1; font-weight: 950; margin-top: 8rpx; }
.page-subtitle { color: rgba(255,255,255,.68); font-size: 24rpx; margin-top: 8rpx; }
.music { min-width: 150rpx; text-align: center; }
.match-tabs { white-space: nowrap; margin-bottom: 18rpx; }
.match-tab { display: inline-flex; flex-direction: column; justify-content: center; min-width: 178rpx; height: 88rpx; margin-right: 14rpx; padding: 0 18rpx; border-radius: 18rpx; color: rgba(255,255,255,.72); background: rgba(255,255,255,.08); border: 1rpx solid rgba(255,255,255,.12); font-size: 22rpx; }
.match-tab text:last-child { margin-top: 4rpx; color: #f6c453; font-size: 24rpx; font-weight: 800; }
.match-tab.active { color: #07142f; background: #08d9d6; box-shadow: 0 10rpx 24rpx rgba(8,217,214,.22); }
.match-tab.active text:last-child { color: #07142f; }
.current-match { padding: 26rpx; }
.match-meta, .match-time { color: rgba(255,255,255,.62); font-size: 22rpx; }
.teams { display: grid; grid-template-columns: 1fr 70rpx 1fr; align-items: center; gap: 10rpx; margin: 16rpx 0 12rpx; color: #fff; font-size: 32rpx; font-weight: 950; }
.teams text:last-child { text-align: right; }
.vs { color: #f6c453; text-align: center !important; font-size: 24rpx; }
.story { margin-top: 16rpx; color: rgba(255,255,255,.78); font-size: 24rpx; line-height: 1.55; }
.ai-card, .form-card, .saved-card { margin-top: 22rpx; }
.compact { margin: 0 0 12rpx; font-size: 28rpx; }
.ai-line { margin-top: 12rpx; color: rgba(255,255,255,.76); font-size: 24rpx; line-height: 1.55; }
.ai-line text { display: inline-block; min-width: 72rpx; margin-right: 10rpx; color: #f6c453; font-weight: 900; }
.ai-notice { margin-top: 16rpx; padding-top: 14rpx; border-top: 1rpx solid rgba(255,255,255,.12); color: rgba(255,255,255,.55); font-size: 21rpx; }
.form-card { padding: 26rpx; }
.field-title { margin: 24rpx 0 12rpx; color: #fff; font-size: 26rpx; font-weight: 900; }
.option-grid { display: grid; gap: 12rpx; }
.option-grid.four { grid-template-columns: repeat(4, 1fr); }
.option-grid.three { grid-template-columns: repeat(3, 1fr); }
.option-grid.two { grid-template-columns: repeat(2, 1fr); }
.option, .chip { min-height: 70rpx; display: flex; align-items: center; justify-content: center; border-radius: 16rpx; background: rgba(255,255,255,.08); border: 1rpx solid rgba(255,255,255,.14); color: rgba(255,255,255,.78); font-size: 24rpx; font-weight: 800; }
.option.selected, .chip.selected { color: #07142f; background: #f6c453; border-color: #f6c453; }
.chips { white-space: nowrap; margin-bottom: 12rpx; }
.chip { display: inline-flex; min-width: 140rpx; padding: 0 16rpx; margin-right: 12rpx; }
.chip.boot.selected { background: #08d9d6; border-color: #08d9d6; }
.reason-input { width: 100%; box-sizing: border-box; min-height: 132rpx; padding: 18rpx; border-radius: 18rpx; background: rgba(255,255,255,.08); color: #fff; border: 1rpx solid rgba(255,255,255,.14); font-size: 24rpx; line-height: 1.5; }
.submit { margin-top: 24rpx; }
.saved-main { color: #f6c453; font-size: 46rpx; font-weight: 950; }
.saved-line { margin-top: 10rpx; color: rgba(255,255,255,.72); font-size: 24rpx; line-height: 1.5; }
.saved-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 20rpx; }
.notice-card { margin-top: 24rpx; padding: 22rpx; border-radius: 18rpx; background: rgba(255,107,107,.1); border: 1rpx solid rgba(255,107,107,.28); color: rgba(255,255,255,.72); font-size: 22rpx; line-height: 1.55; }
