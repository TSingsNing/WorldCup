.quiz-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 24rpx; }
.eyebrow { color: #08d9d6; font-size: 24rpx; font-weight: 850; letter-spacing: 3rpx; }
.title { margin-top: 12rpx; font-size: 46rpx; font-weight: 900; }
.score-pill { padding: 14rpx 22rpx; border-radius: 999rpx; color: #061124; background: #f6c453; font-size: 24rpx; font-weight: 900; white-space: nowrap; }
.progress-wrap { margin-top: 34rpx; height: 14rpx; border-radius: 999rpx; overflow: hidden; background: rgba(255,255,255,.12); }
.progress-bar { height: 100%; border-radius: 999rpx; background: linear-gradient(90deg, #08d9d6, #f6c453); transition: width .25s ease; }
.question-card { margin-top: 36rpx; padding: 34rpx; }
.question-text { font-size: 36rpx; line-height: 1.55; font-weight: 850; }
.option-list { margin-top: 34rpx; display: flex; flex-direction: column; gap: 20rpx; }
.option-card { display: flex; align-items: center; gap: 22rpx; min-height: 96rpx; padding: 18rpx 22rpx; border: 2rpx solid rgba(255,255,255,.14); border-radius: 24rpx; background: rgba(255,255,255,.08); transition: all .2s ease; }
.option-card:active { transform: scale(.99); }
.option-letter { display: flex; align-items: center; justify-content: center; width: 54rpx; height: 54rpx; border-radius: 50%; color: #061124; background: rgba(255,255,255,.9); font-size: 26rpx; font-weight: 900; }
.option-text { flex: 1; font-size: 29rpx; line-height: 1.45; }
.option-correct { border-color: #08d9d6; background: rgba(8,217,214,.2); }
.option-wrong { border-color: #ff6b6b; background: rgba(255,107,107,.22); }
.feedback-card { margin-top: 28rpx; padding: 28rpx; }
.feedback-card.success { border-color: rgba(8,217,214,.5); }
.feedback-card.fail { border-color: rgba(255,107,107,.5); }
.feedback-title { font-size: 32rpx; font-weight: 900; }
.feedback-desc { margin-top: 14rpx; color: rgba(255,255,255,.76); font-size: 27rpx; line-height: 1.65; }
.action-area { margin-top: 34rpx; }
