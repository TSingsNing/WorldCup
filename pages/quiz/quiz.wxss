.quiz-page { height: 100vh; min-height: 100vh; box-sizing: border-box; overflow: hidden; padding: 24rpx; display: flex; flex-direction: column; }
.scoreboard { flex-shrink: 0; display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; padding: 22rpx 24rpx; }
.score-main { min-width: 0; flex: 1; }
.title { margin-top: 6rpx; font-size: 38rpx; line-height: 1.1; }
.roast { margin-top: 10rpx; color: rgba(255,255,255,.78); font-size: 22rpx; line-height: 1.36; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.score-box { flex-shrink: 0; min-width: 108rpx; padding: 12rpx 10rpx; border: 4rpx solid #FFD84D; border-radius: 10rpx; background: rgba(255,216,77,.12); text-align: center; }
.score-num { color: #FFD84D; font-size: 38rpx; font-weight: 950; line-height: 1; }
.score-label, .miss-label { margin-top: 5rpx; color: rgba(255,255,255,.72); font-size: 18rpx; font-weight: 900; }
.miss-label { color: #FFB7A5; }
.broadcast-strip { display: none; }
.pixel-progress { flex-shrink: 0; margin-top: 18rpx; height: 18rpx; border: 3rpx solid rgba(255,255,255,.72); border-radius: 8rpx; background: rgba(0,0,0,.30); overflow: hidden; box-shadow: 5rpx 5rpx 0 rgba(0,0,0,.32); }
.progress-grass { height: 100%; background: repeating-linear-gradient(90deg, #7CFF6B 0 24rpx, #FFD84D 24rpx 32rpx); transition: width .25s ease; }
.question-card { flex: 1; min-height: 0; margin-top: 18rpx; padding: 24rpx; display: flex; flex-direction: column; justify-content: space-between; }
.field-lines { pointer-events: none; position: absolute; inset: 0; opacity: .13; border: 4rpx solid #ffffff; }
.field-lines::before { content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 4rpx; background: #ffffff; }
.center-circle { position: absolute; left: 50%; top: 50%; width: 146rpx; height: 146rpx; margin-left: -73rpx; margin-top: -73rpx; border: 4rpx solid #ffffff; border-radius: 50%; }
.question-text { position: relative; flex-shrink: 0; font-size: 31rpx; line-height: 1.40; font-weight: 950; }
.option-list { position: relative; flex-shrink: 0; margin-top: 18rpx; display: flex; flex-direction: column; gap: 13rpx; }
.option-card { display: flex; align-items: center; gap: 14rpx; min-height: 70rpx; padding: 11rpx 14rpx; border: 4rpx solid rgba(255,255,255,.24); border-radius: 10rpx; background: rgba(11,43,24,.90); box-shadow: 4rpx 4rpx 0 rgba(0,0,0,.28); }
.option-card:active { transform: translate(3rpx, 3rpx); box-shadow: 2rpx 2rpx 0 rgba(0,0,0,.30); }
.option-letter { display: flex; align-items: center; justify-content: center; width: 48rpx; height: 48rpx; border: 3rpx solid #071A0F; border-radius: 6rpx; color: #071A0F; background: #ffffff; font-size: 23rpx; font-weight: 950; }
.option-text { flex: 1; color: #ffffff; font-size: 25rpx; line-height: 1.33; font-weight: 800; }
.option-correct { border-color: #7CFF6B; background: rgba(37, 122, 52, .92); }
.option-wrong { border-color: #FF7A59; background: rgba(119, 36, 28, .92); }
.result-card { position: relative; flex-shrink: 0; margin-top: 18rpx; min-height: 188rpx; padding: 18rpx; border: 4rpx solid #FFD84D; border-radius: 10rpx; background: rgba(0,0,0,.30); box-shadow: inset 0 0 0 2rpx rgba(255,255,255,.08); }
.result-card.idle { border-color: rgba(255,255,255,.35); background: rgba(5,25,14,.58); }
.result-card.success { border-color: #7CFF6B; }
.result-card.fail { border-color: #FF7A59; }
.result-head { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.result-tag { color: #FFD84D; font-size: 25rpx; font-weight: 950; }
.result-status { padding: 6rpx 10rpx; border-radius: 6rpx; color: #071A0F; background: #E7FFD8; font-size: 20rpx; font-weight: 950; white-space: nowrap; }
.answer-row { display: flex; gap: 10rpx; margin-top: 12rpx; }
.answer-pill { flex: 1; padding: 9rpx 10rpx; border: 3rpx solid rgba(255,255,255,.34); border-radius: 8rpx; color: #ffffff; font-size: 21rpx; font-weight: 950; text-align: center; }
.answer-pill.truth { border-color: #7CFF6B; color: #7CFF6B; }
.answer-pill.mine { border-color: #FFD84D; color: #FFD84D; }
.result-desc { margin-top: 12rpx; color: rgba(255,255,255,.86); font-size: 23rpx; line-height: 1.40; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.feedback-action { margin-top: 12rpx; }
.compact-button { min-height: 64rpx; font-size: 25rpx; box-shadow: 5rpx 5rpx 0 rgba(0,0,0,.38), inset -4rpx -4rpx 0 rgba(0,0,0,.12); }
