.quiz-page { height: 100vh; min-height: 100vh; box-sizing: border-box; overflow: hidden; padding: 22rpx 24rpx 24rpx; display: flex; flex-direction: column; }
.scoreboard { flex-shrink: 0; display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; padding: 20rpx 22rpx; }
.score-main { min-width: 0; flex: 1; }
.title { margin-top: 6rpx; font-size: 36rpx; line-height: 1.08; }
.roast { margin-top: 8rpx; color: rgba(255,255,255,.76); font-size: 21rpx; line-height: 1.32; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.score-box { flex-shrink: 0; min-width: 104rpx; padding: 10rpx 8rpx; border: 4rpx solid #FFD84D; border-radius: 10rpx; background: rgba(255,216,77,.12); text-align: center; }
.score-num { color: #FFD84D; font-size: 36rpx; font-weight: 950; line-height: 1; }
.score-label, .miss-label { margin-top: 4rpx; color: rgba(255,255,255,.72); font-size: 18rpx; font-weight: 900; }
.miss-label { color: #FFB7A5; }
.broadcast-strip { display: none; }
.pixel-progress { flex-shrink: 0; margin-top: 18rpx; height: 16rpx; border: 3rpx solid rgba(255,255,255,.72); border-radius: 8rpx; background: rgba(0,0,0,.30); overflow: hidden; box-shadow: 5rpx 5rpx 0 rgba(0,0,0,.32); }
.progress-grass { height: 100%; background: repeating-linear-gradient(90deg, #7CFF6B 0 24rpx, #FFD84D 24rpx 32rpx); transition: width .25s ease; }
.question-card { flex: 1; min-height: 0; margin-top: 18rpx; padding: 22rpx; display: flex; flex-direction: column; }
.field-lines { pointer-events: none; position: absolute; inset: 0; opacity: .12; border: 4rpx solid #ffffff; }
.field-lines::before { content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 4rpx; background: #ffffff; }
.center-circle { position: absolute; left: 50%; top: 50%; width: 132rpx; height: 132rpx; margin-left: -66rpx; margin-top: -66rpx; border: 4rpx solid #ffffff; border-radius: 50%; }
.question-text { position: relative; flex-shrink: 0; font-size: 29rpx; line-height: 1.36; font-weight: 950; }
.option-list { position: relative; flex-shrink: 0; margin-top: 18rpx; display: flex; flex-direction: column; gap: 12rpx; }
.option-card { display: flex; align-items: center; gap: 14rpx; min-height: 66rpx; padding: 10rpx 14rpx; border: 4rpx solid rgba(255,255,255,.24); border-radius: 10rpx; background: rgba(11,43,24,.90); box-shadow: 4rpx 4rpx 0 rgba(0,0,0,.28); }
.option-card:active { transform: translate(3rpx, 3rpx); box-shadow: 2rpx 2rpx 0 rgba(0,0,0,.30); }
.option-letter { display: flex; align-items: center; justify-content: center; width: 46rpx; height: 46rpx; border: 3rpx solid #071A0F; border-radius: 6rpx; color: #071A0F; background: #ffffff; font-size: 22rpx; font-weight: 950; }
.option-text { flex: 1; color: #ffffff; font-size: 25rpx; line-height: 1.32; font-weight: 800; }
.option-correct { border-color: #7CFF6B; background: rgba(37, 122, 52, .92); }
.option-wrong { border-color: #FF7A59; background: rgba(119, 36, 28, .92); }
.feedback-card { position: relative; flex-shrink: 0; margin-top: 16rpx; padding: 16rpx; border: 4rpx solid #FFD84D; border-radius: 10rpx; background: rgba(0,0,0,.28); }
.feedback-card.success { border-color: #7CFF6B; }
.feedback-card.fail { border-color: #FF7A59; }
.feedback-title { color: #FFD84D; font-size: 25rpx; font-weight: 950; }
.feedback-desc { margin-top: 8rpx; color: rgba(255,255,255,.84); font-size: 22rpx; line-height: 1.36; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.feedback-action { margin-top: 12rpx; }
.compact-button { min-height: 62rpx; font-size: 25rpx; box-shadow: 5rpx 5rpx 0 rgba(0,0,0,.38), inset -4rpx -4rpx 0 rgba(0,0,0,.12); }
