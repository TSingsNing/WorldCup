.quiz-page { overflow: hidden; }
.scoreboard { display: flex; align-items: flex-start; justify-content: space-between; gap: 22rpx; padding: 28rpx; }
.title { margin-top: 12rpx; font-size: 44rpx; }
.roast { margin-top: 12rpx; color: rgba(255,255,255,.72); font-size: 24rpx; line-height: 1.55; }
.score-box { min-width: 118rpx; padding: 14rpx 10rpx; border: 4rpx solid #FFD84D; border-radius: 10rpx; background: rgba(255,216,77,.12); text-align: center; }
.score-num { color: #FFD84D; font-size: 42rpx; font-weight: 950; line-height: 1; }
.score-label, .miss-label { margin-top: 6rpx; color: rgba(255,255,255,.72); font-size: 20rpx; font-weight: 900; }
.miss-label { color: #FFB7A5; }

.broadcast-strip { margin-top: 22rpx; padding: 18rpx 22rpx; border: 4rpx solid #FFD84D; border-radius: 10rpx; background: rgba(0,0,0,.30); box-shadow: 6rpx 6rpx 0 rgba(0,0,0,.30); }
.broadcast-title { color: #FFD84D; font-size: 25rpx; font-weight: 950; letter-spacing: 1rpx; }
.broadcast-line { margin-top: 8rpx; color: rgba(255,255,255,.80); font-size: 24rpx; line-height: 1.5; }

.pixel-progress { margin-top: 30rpx; height: 22rpx; border: 4rpx solid rgba(255,255,255,.72); border-radius: 8rpx; background: rgba(0,0,0,.30); overflow: hidden; box-shadow: 6rpx 6rpx 0 rgba(0,0,0,.32); }
.progress-grass { height: 100%; background: repeating-linear-gradient(90deg, #7CFF6B 0 24rpx, #FFD84D 24rpx 32rpx); transition: width .25s ease; }
.question-card { margin-top: 34rpx; padding: 32rpx; }
.field-lines { pointer-events: none; position: absolute; inset: 0; opacity: .17; border: 4rpx solid #ffffff; }
.field-lines::before { content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 4rpx; background: #ffffff; }
.center-circle { position: absolute; left: 50%; top: 50%; width: 160rpx; height: 160rpx; margin-left: -80rpx; margin-top: -80rpx; border: 4rpx solid #ffffff; border-radius: 50%; }
.question-text { position: relative; margin-top: 24rpx; font-size: 34rpx; line-height: 1.58; font-weight: 950; }
.option-list { position: relative; margin-top: 34rpx; display: flex; flex-direction: column; gap: 20rpx; }
.option-card { display: flex; align-items: center; gap: 20rpx; min-height: 94rpx; padding: 18rpx 20rpx; border: 4rpx solid rgba(255,255,255,.24); border-radius: 10rpx; background: rgba(11,43,24,.90); box-shadow: 5rpx 5rpx 0 rgba(0,0,0,.28); }
.option-card:active { transform: translate(3rpx, 3rpx); box-shadow: 2rpx 2rpx 0 rgba(0,0,0,.30); }
.option-letter { display: flex; align-items: center; justify-content: center; width: 56rpx; height: 56rpx; border: 3rpx solid #071A0F; border-radius: 6rpx; color: #071A0F; background: #ffffff; font-size: 26rpx; font-weight: 950; }
.option-text { flex: 1; color: #ffffff; font-size: 29rpx; line-height: 1.48; font-weight: 800; }
.option-correct { border-color: #7CFF6B; background: rgba(37, 122, 52, .92); }
.option-wrong { border-color: #FF7A59; background: rgba(119, 36, 28, .92); }
.feedback-card { margin-top: 28rpx; padding: 28rpx; }
.feedback-card.success { border-color: #7CFF6B; }
.feedback-card.fail { border-color: #FF7A59; }
.feedback-title { color: #FFD84D; font-size: 32rpx; font-weight: 950; }
.feedback-desc { margin-top: 14rpx; color: rgba(255,255,255,.80); font-size: 27rpx; line-height: 1.68; }
.action-area { margin-top: 34rpx; }
