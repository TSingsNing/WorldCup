.cert-hero { padding: 30rpx; }
.title { margin-top: 12rpx; font-size: 48rpx; line-height: 1.16; }
.grade-chip { display: inline-flex; margin-top: 22rpx; padding: 10rpx 16rpx; border: 4rpx solid #FFD84D; border-radius: 8rpx; background: rgba(0,0,0,.26); font-size: 24rpx; font-weight: 950; }
.subtitle { margin-top: 18rpx; color: rgba(255,255,255,.80); font-size: 27rpx; line-height: 1.68; }

.final-card { margin-top: 26rpx; padding: 26rpx; }
.final-score { color: #FFD84D; font-size: 42rpx; font-weight: 950; text-shadow: 4rpx 4rpx 0 rgba(0,0,0,.38); }
.final-title { margin-top: 10rpx; color: #7CFF6B; font-size: 30rpx; font-weight: 950; }
.final-desc { margin-top: 12rpx; color: rgba(255,255,255,.78); font-size: 25rpx; line-height: 1.6; }
.persona-label { display: inline-flex; margin-top: 22rpx; padding: 6rpx 12rpx; border: 3rpx solid #FFD84D; border-radius: 6rpx; color: #071A0F; background: #FFD84D; font-size: 20rpx; font-weight: 950; }
.persona-name { margin-top: 12rpx; color: #ffffff; font-size: 34rpx; font-weight: 950; }
.persona-slogan { margin-top: 10rpx; color: rgba(255,255,255,.76); font-size: 24rpx; line-height: 1.55; }

.stat-grid { margin-top: 26rpx; display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx; }
.stat-card { padding: 18rpx 8rpx; text-align: center; }
.stat-num { color: #FFD84D; font-size: 30rpx; font-weight: 950; }
.stat-label { margin-top: 6rpx; color: rgba(255,255,255,.70); font-size: 20rpx; font-weight: 900; }
.canvas-wrap { margin-top: 30rpx; padding: 18rpx; }
.certificate-canvas { width: 654rpx; height: 960rpx; border-radius: 8rpx; overflow: hidden; }
.button-group { margin-top: 34rpx; display: flex; flex-direction: column; gap: 20rpx; }
