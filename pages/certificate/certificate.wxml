<view class="container cert-page pixel-field">
  <view class="cert-hero pixel-panel">
    <view class="eyebrow">SHAREABLE PIXEL CERTIFICATE</view>
    <view class="title">你的球场证书出炉</view>
    <view class="grade-chip" style="border-color: {{accent}}; color: {{accent}};">{{grade}} · {{seal}}</view>
    <view class="subtitle">{{gradeSlogan}}</view>
  </view>

  <view class="stat-grid">
    <view class="stat-card glass-card"><view class="stat-num">{{correct}}/{{total}}</view><view class="stat-label">命中</view></view>
    <view class="stat-card glass-card"><view class="stat-num">{{accuracy}}%</view><view class="stat-label">正确率</view></view>
    <view class="stat-card glass-card"><view class="stat-num">{{score}}</view><view class="stat-label">积分</view></view>
  </view>

  <view class="canvas-wrap glass-card">
    <canvas type="2d" class="certificate-canvas" id="certificateCanvas"></canvas>
  </view>
  <view class="button-group">
    <view class="primary-button" bindtap="saveCertificate">保存证书</view>
    <view class="ghost-button" bindtap="goLeaderboard">查看好友段位榜</view>
    <view class="ghost-button" bindtap="backHome">再开一局</view>
  </view>
</view>
