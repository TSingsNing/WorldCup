<view class="container cert-page">
  <view class="cert-hero">
    <view class="eyebrow">SHAREABLE CHAOS CERTIFICATE</view>
    <view class="title">你的球格证书出炉</view>
    <view class="subtitle">{{type}}，{{level}}。这张不太正经，但很适合发群里让朋友破防。</view>
  </view>

  <view class="canvas-wrap glass-card">
    <canvas class="certificate-canvas" canvas-id="certificateCanvas" id="certificateCanvas"></canvas>
  </view>

  <view class="button-group">
    <view class="primary-button" bindtap="saveCertificate">保存后发群炫耀</view>
    <view class="ghost-button" bindtap="goLeaderboard">查看好友段位榜</view>
    <view class="ghost-button" bindtap="backHome">再开一局</view>
  </view>
</view>
